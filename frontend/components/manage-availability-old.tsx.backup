"use client";

import React, { useState, useEffect, FormEvent } from "react";
import { useDispatch, useSelector } from "react-redux";
import { AppDispatch, RootState } from "@/store/store";
import {
  fetchAvailabilityTemplate,
  saveAvailabilityTemplate,
  AvailabilitySlot,
} from "@/store/slices/availabilitySlice";
import {
  Card,
  CardContent,
  CardHeader,
  CardTitle,
  CardFooter,
} from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { Switch } from "@/components/ui/switch";
import { Trash2, PlusCircle, Clock, Calendar, Loader2 } from "lucide-react";
import toast from "react-hot-toast";
import { InfinitySpin } from "react-loader-spinner";
import { Badge } from "@/components/ui/badge";

// Helper to format time from "HH:mm:ss.ffffff" to "HH:mm"
const formatTime = (timeStr: string) => timeStr.substring(0, 5);

const daysOfWeek = [
  "Monday",
  "Tuesday",
  "Wednesday",
  "Thursday",
  "Friday",
  "Saturday",
  "Sunday",
];

export default function ManageAvailability() {
  const dispatch = useDispatch<AppDispatch>();
  const { template, status } = useSelector(
    (state: RootState) => state.availability
  );

  // Local state to manage edits before saving
  const [localSlots, setLocalSlots] = useState<AvailabilitySlot[]>([]);

  // State for the "Add New Slot" form
  const [newSlot, setNewSlot] = useState<Partial<AvailabilitySlot>>({
    day_of_week: "Monday",
    start_time: "09:00",
    end_time: "17:00",
    slot_duration_minutes: 30,
    is_telemedicine: false,
  });

  // Fetch data on initial load
  useEffect(() => {
    dispatch(fetchAvailabilityTemplate());
  }, [dispatch]);

  // Sync local state when Redux state updates
  useEffect(() => {
    if (template.slots) {
      setLocalSlots(template.slots);
    }
  }, [template]);

  const handleAddSlot = (e: FormEvent) => {
    e.preventDefault();
    if (
      !newSlot.day_of_week ||
      !newSlot.start_time ||
      !newSlot.end_time ||
      !newSlot.slot_duration_minutes
    ) {
      toast.error("Please fill all fields for the new slot.");
      return;
    }
    setLocalSlots([...localSlots, newSlot as AvailabilitySlot]);
  };

  const handleRemoveSlot = (indexToRemove: number) => {
    setLocalSlots(localSlots.filter((_, index) => index !== indexToRemove));
  };

  const handleSave = () => {
    toast.promise(
      dispatch(saveAvailabilityTemplate({ slots: localSlots })).unwrap(),
      {
        loading: "Saving availability...",
        success: "Availability template saved successfully!",
        error: (err) => err || "Failed to save template.",
      }
    );
  };

  if (status === "loading" && !localSlots.length) {
    return (
      <div className="flex justify-center p-10">
        <InfinitySpin color="#388fe5" />
      </div>
    );
  }

  return (
    <div className="grid gap-6">
      {/* --- Add New Slot Form --- */}
      <Card className="shadow-sm">
        <CardHeader className="bg-gradient-to-r from-[#388fe5]/10 to-transparent">
          <div className="flex items-center gap-2">
            <div className="p-2 bg-[#388fe5] rounded-lg">
              <PlusCircle className="h-5 w-5 text-white" />
            </div>
            <CardTitle>Add New Availability Slot</CardTitle>
          </div>
        </CardHeader>
        <form onSubmit={handleAddSlot}>
          <CardContent className="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-4">
            <div>
              <Label htmlFor="day">Day</Label>
              <select
                id="day"
                className="w-full mt-1 p-2 border rounded-md"
                value={newSlot.day_of_week}
                onChange={(e) =>
                  setNewSlot({ ...newSlot, day_of_week: e.target.value })
                }
              >
                {daysOfWeek.map((day) => (
                  <option key={day} value={day}>
                    {day}
                  </option>
                ))}
              </select>
            </div>
            <div>
              <Label htmlFor="start-time">Start Time</Label>
              <Input
                id="start-time"
                type="time"
                value={newSlot.start_time}
                onChange={(e) =>
                  setNewSlot({ ...newSlot, start_time: e.target.value })
                }
              />
            </div>
            <div>
              <Label htmlFor="end-time">End Time</Label>
              <Input
                id="end-time"
                type="time"
                value={newSlot.end_time}
                onChange={(e) =>
                  setNewSlot({ ...newSlot, end_time: e.target.value })
                }
              />
            </div>
            <div>
              <Label htmlFor="duration">Slot Duration (min)</Label>
              <Input
                id="duration"
                type="number"
                min="5"
                value={newSlot.slot_duration_minutes}
                onChange={(e) =>
                  setNewSlot({
                    ...newSlot,
                    slot_duration_minutes: parseInt(e.target.value, 10),
                  })
                }
              />
            </div>
            <div className="flex flex-col justify-center gap-2 pt-5">
              <Label htmlFor="telemedicine">Telemedicine</Label>
              <Switch
                id="telemedicine"
                checked={newSlot.is_telemedicine}
                onCheckedChange={(checked) =>
                  setNewSlot({ ...newSlot, is_telemedicine: checked })
                }
              />
            </div>
          </CardContent>
          <CardFooter>
            <Button type="submit" className="bg-[#388fe5] hover:bg-[#6fb043] text-white">
              <PlusCircle className="mr-2 h-4 w-4" /> Add Slot
            </Button>
          </CardFooter>
        </form>
      </Card>

      {/* --- Current Availability Template --- */}
      <Card className="shadow-sm">
        <CardHeader className="bg-gradient-to-r from-[#388fe5]/10 to-transparent">
          <div className="flex items-center gap-2">
            <div className="p-2 bg-[#388fe5] rounded-lg">
              <Calendar className="h-5 w-5 text-white" />
            </div>
            <CardTitle>Current Availability Template</CardTitle>
          </div>
        </CardHeader>
        <CardContent>
          <div className="space-y-4">
            {daysOfWeek.map((day) => {
              const slotsForDay = localSlots.filter(
                (slot) => slot.day_of_week === day
              );
              if (slotsForDay.length === 0) return null; // Don't show day if no slots

              return (
                <div key={day} className="space-y-3">
                  <div className="flex items-center gap-2 mb-3">
                    <div className="h-1 w-1 rounded-full bg-[#388fe5]" />
                    <h3 className="font-semibold text-lg text-gray-900">{day}</h3>
                  </div>
                  <div className="space-y-2 pl-4">
                    {slotsForDay.map((slot, index) => {
                      // Use a unique key based on content and index
                      const uniqueKey = `${day}-${slot.start_time}-${index}`;
                      return (
                        <div
                          key={uniqueKey}
                          className="flex items-center justify-between p-4 bg-white border border-gray-200 rounded-lg hover:border-[#388fe5] hover:shadow-sm transition-all group"
                        >
                          <div className="flex items-center gap-4">
                            <div className="p-2 bg-[#388fe5]/10 rounded-lg">
                              <Clock className="h-4 w-4 text-[#388fe5]" />
                            </div>
                            <span className="font-mono text-md font-medium text-gray-900">
                              {formatTime(slot.start_time)} -{" "}
                              {formatTime(slot.end_time)}
                            </span>
                            <Badge
                              className={
                                slot.is_telemedicine 
                                  ? "bg-[#388fe5] hover:bg-[#6fb043] text-white" 
                                  : "bg-blue-100 text-blue-700 hover:bg-blue-200"
                              }
                            >
                              {slot.is_telemedicine
                                ? "Telemedicine"
                                : "In-Person"}
                            </Badge>
                            <span className="text-sm text-gray-500">
                              ({slot.slot_duration_minutes} min slots)
                            </span>
                          </div>
                          <Button
                            variant="ghost"
                            size="icon"
                            onClick={() =>
                              handleRemoveSlot(localSlots.indexOf(slot))
                            }
                            className="hover:bg-red-50"
                          >
                            <Trash2 className="h-4 w-4 text-red-500" />
                          </Button>
                        </div>
                      );
                    })}
                  </div>
                </div>
              );
            })}
            {localSlots.length === 0 && (
              <p className="text-center text-gray-500 py-4">
                No availability slots have been added. Use the form above to
                create your schedule.
              </p>
            )}
          </div>
        </CardContent>
        <CardFooter className="flex justify-end bg-gray-50">
          <Button 
            onClick={handleSave} 
            disabled={status === "loading"}
            className="bg-[#388fe5] hover:bg-[#6fb043] text-white"
          >
            {status === "loading" ? (
              <>
                <Loader2 className="w-4 h-4 mr-2 animate-spin" />
                Saving...
              </>
            ) : (
              "Save Changes"
            )}
          </Button>
        </CardFooter>
      </Card>
    </div>
  );
}
